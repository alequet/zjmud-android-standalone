+int prepare_ai_login()
+{
+	string id;
+
+	id = query("id");
+	if (base_name(previous_object()) != "/adm/daemons/ai_playerd" ||
+	    ! stringp(id) || strsrch(id, "ai_") != 0)
+		return 0;
+
+	set_temp("ai_login", 1);
+	seteuid(0);
+	return ! stringp(geteuid(this_object()));
+}
+
+int activate_ai_login()
+{
+	string id;
+
+	id = query("id");
+	if (! query_temp("ai_login") ||
+	    base_name(previous_object()) != "/adm/daemons/logind" ||
+	    ! stringp(id) || strsrch(id, "ai_") != 0 || getuid() != id)
+		return 0;
+
+	seteuid(getuid());
+	return geteuid(this_object()) == getuid(this_object());
+}
