+void repair_jiuyang_book(object me)
+{
+	object ob;
+
+	if (! objectp(me) ||
+	    me->query("zjvip/vipgift/jiuyang_book_repaired") ||
+	    me->query_skill("jiuyang-shengong", 1) != 50 ||
+	    (! me->query("zjvip/vipgift/vip3") &&
+	     ! me->query("zjvip/vipgift/vip4")))
+		return;
+
+	if (objectp(present("jiuyang zhenjing", me)))
+	{
+		me->set("zjvip/vipgift/jiuyang_book_repaired", 1);
+		return;
+	}
+
+	ob = new("/clone/book/jiuyang-book");
+	if (! objectp(ob) || ! ob->move(me, 1))
+		return;
+
+	me->set("zjvip/vipgift/jiuyang_book_repaired", 1);
+	tell_object(me, HIG "VIP Jiuyang reward book restored.\n" NOR);
+	log_ufile(me, "viplvgift", "Restored missing Jiuyang reward book.\n");
+}
